  "servers": [
    {
      "url": "https://digi-api.com/api/v1",
      "description": "Production server"
    }
  ],
  "paths": {
    "/digimon/{idOrName}": {
      "get": {
        "summary": "Get Digimon by ID or Name",
        "description": "Returns a digimon and all its information by ID or name",
        "operationId": "getDigimon",
        "tags": [
          "Digimon"
        ],
        "parameters": [
          {
            "name": "idOrName",
            "in": "path",
            "required": true,
            "description": "Digimon unique ID or name",
            "schema": {
              "oneOf": [
                {
                  "type": "integer"
                },
                {
                  "type": "string"
                }
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Digimon"
                }
              }
            }
          },
          "404": {
            "description": "Digimon not found"
          }
        }
      }
    },
    "/digimon": {
      "get": {
        "summary": "Get Digimon List",
        "description": "Returns a paged list of digimons in this API",
        "operationId": "getDigimonList",
        "tags": [
          "Digimon"
        ],
        "parameters": [
          {
            "name": "name",
            "in": "query",
            "description": "Returns a list of digimons that have a similar name to the value",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "exact",
            "in": "query",
            "description": "Will search for the exact string passed in the 'name' parameter",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "attribute",
            "in": "query",
            "description": "Returns a list of digimons with the attribute equal to value (Case Insensitive)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "xAntibody",
            "in": "query",
            "description": "Returns a list of digimons with the xAntibody equal to value",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "level",
            "in": "query",
            "description": "Returns a list of digimons with the level equal to value (Case Insensitive)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "page",
            "in": "query",
            "description": "Used to navigate to a specific page",
            "schema": {
              "type": "integer",
              "default": 0
            }
          },
          {
            "name": "pageSize",
            "in": "query",
            "description": "Changes the quantity of rows returned for each page",
            "schema": {
              "type": "integer",
              "default": 20
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DigimonList"
                }
              }
            }
          }
        }
      }
    },
